#include <bits/stdc++.h>
using namespace std;
#define ll long long

int main(){
    cin.tie(0)->sync_with_stdio(0);
    int t; cin >> t;
    while(t--){
        int n;cin >> n;
        int mx = 0, mx2 = 0;
        int pos = -1;
        int v[n];
        for(int i = 0 ;i<n; i++){
            cin >> v[i];
            if(v[i] > mx){
                pos = i;
                mx = v[i];
            }
            
        }
        for(int i = 0 ;i < n; i++){
            if(i != pos && mx2 < v[i]){
                mx2 = v[i];
            }
            
        }
        for(int i = 0 ;i<n; i++){
            if(i != pos)
            cout << v[i] - mx << " ";
            else
            cout << v[i] - mx2 << " "; 
        }
        cout << '\n';
    }
    return 0;
}
