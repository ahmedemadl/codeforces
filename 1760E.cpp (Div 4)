#include <bits/stdc++.h>
using namespace std;
#define ll long long

const  int N = 2*1e5 ;
vector<int> v(N);
int n;
ll maxi(){  
    ll zero= 0;
    ll res = 0;
    for(int i = n - 1 ;i >= 0 ;i--){
        if(v[i] == 1){
            res += zero;
        }
        else{
            zero++;
        }
    }
    return res;

}

int main(){
    cin.tie(0)->sync_with_stdio(0);
    int t; cin >> t;
    while(t--){
        cin >> n;
        int pos1 = -1;
        for(int i = 0 ;i < n ;i++){
            cin >> v[i];
            if(v[i] == 0 && pos1 == -1){
                pos1= i;
                
            }
        }
        ll ans = maxi();
        int pos=-1;
        vector<int> temp = v;
        for(int i = n-1 ;i >= 0;i--){
            if(v[i] == 1){
                v[i] = 0;
                pos = i;
                break;
            } 
        }
        ans = max(ans, maxi());
        if(pos != -1){
            v[pos]^=1;
        }

        // for(int i = 0 ;i < n;i++){
        //     if(v[i] == 0){
        //         v[i] = 1;
        //         break;
        //     } 
        // }
        if(pos1 != -1){
            v[pos1]^=1;
        }
        ans = max(ans, maxi());
        cout << ans << '\n';
        
    }
    return 0;
}
