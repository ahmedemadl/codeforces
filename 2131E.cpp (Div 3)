#include <bits/stdc++.h>
using namespace std;
#define ll long long

int main(){
    cin.tie(0)->sync_with_stdio(0);
    int t; cin >> t;
    while(t--){
        int n;cin >> n;
        vector<int> a(n), b(n);
        for(int &i : a) cin >> i;
        for(int &i : b) cin >> i;
        vector<int> c = a;
        string ans = "YES\n";
        
        if(a[n-1] != b[n-1]){
            ans = "NO\n";
        }

        for(int i = n-2; i >= 0 ; i--){
            if(a[i] != b[i] && (a[i]^ a[i+1]) == b[i]){
                c[i] ^= c[i+1];
            }else if(a[i] != b[i] && (a[i]^ b[i+1]) == b[i]){
                c[i] ^= c[i+1];
            }else if(a[i] != b[i]){
                ans = "NO\n";
                break;
            }
        }

        cout << ans;
    }
    return 0;
}
