#include <bits/stdc++.h>
using namespace std;
#define ll long long

int main(){
    cin.tie(0)->sync_with_stdio(0);
    int t; cin >> t;
    while(t--){
        int n;cin >> n;
        vector<int> v;
        int j;cin >> j;
        v.push_back(j);
        for(int i = 1; i< n; i++){
            int num;cin >> num;
            if(num  > v.back()+1){
                v.push_back(num);
            }
        }
        cout << v.size() << '\n';
    }
    return 0;
}
