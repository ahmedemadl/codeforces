#include <bits/stdc++.h>
using namespace std;
#define ll long long
const int N = 1e5 + 1;
vector<pair<ll,pair<ll,ll>>> adj[N];
int n, m, k;
// x is assumed wisdom
bool dijkstra(int x){
    // to sort in a inceasing order
    // first for cost and sec for node
    priority_queue< pair<ll,ll>, vector<pair<ll,ll>>, greater<pair<ll,ll>> > q;
    vector<ll> cost((n + 1), 1e18); // node and cost
    vector<bool> vis(n + 1);
    cost[1] = 0;
    q.push({0,1});
    bool valid = 0;
    while(!q.empty()){
        int node = q.top().second;
        q.pop();
        if(node == n){
            valid = true;
            break;
        }
        if(vis[node]) continue;
        vis[node] = true;
        for(auto child : adj[node]){
            if( cost[child.first] > cost[node] + child.second.first && cost[node] + child.second.first < k && child.second.second <= x){
                cost[child.first] = cost[node] + child.second.first;    
                q.push({ cost[child.first] , child.first });
            }
        }
    }
    return cost[n] != 1e18;
}



int main(){
    cin.tie(0)->sync_with_stdio(0);
    int t; cin >> t;
    while(t--){
        cin >> n >> m >> k;
        // data processing
        for(int i = 0 ;i < m; i++){
            // nodes: a -> b 
            // c: cost
            // w: wisdom
            ll a, b,c, w;cin >> a >> b >> c >> w;
            adj[a].push_back({b, {c, w}});
            adj[b].push_back({a, {c, w}});
        }
        // binary search on x
        // want to minimize
        ll r= 1e9+1, l = 1, mid, ans=-1;
        while(l <= r){
            int mid = l + (r -l)/2;
            if(dijkstra(mid)){
                ans = mid;
                r = mid -1;
            }else{
                l = mid +1;
            }
        }

        cout << ans << '\n';

        // clear
        for(int i = 1; i <= n; i++){
            adj[i].clear();
        }
    }
    return 0;
}
