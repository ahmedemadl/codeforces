#include <bits/stdc++.h>
using namespace std;
#define ll long long

int main(){
    cin.tie(0)->sync_with_stdio(0);
    int t; cin >> t;
    while(t--){
        int n;cin >> n;
        vector<int> v(n);
        int count = 0;
        for(int i = 0; i< n; i++ )cin>> v[i];
        int l = 0 ,r = n-1;
        while(l < n-1 && v[l] >= v[l+1]){
            l++;
        }
        while(r > 0 && v[r] >= v[r-1]){
            r--;
        }
        if(l >= r){
            cout <<"YES\n";
        }else{
            cout << "NO\n";
        }
    }
    return 0;
}
