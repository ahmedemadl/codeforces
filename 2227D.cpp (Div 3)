                    pos_2++;
            }   
            int ans;
            for(int i = 0 ; i < (n/2)+1 ;i++){
                // cout << i << " " << v[i] << " // ";
                if(freq[i] == 0){ ans = i;break;}
            }

            mx = max(ans, mx);
        }
        else{
            mx = 1;
        }
        // option 2
        vector<int> freq1((n/2)+ 1 , 0), freq2((n/2)+ 1 , 0);
        freq1[0]=1;
        freq2[0]=1;
        int pt=1;
        while(pos11 - pt >= 0 && pos11+pt < n && v[pos11-pt] == v[pos11+pt]){
            freq1[v[pos11-pt]]=1;
            pt++;
        }
        pt=1;
        while(pos22 - pt >= 0 && pos22+pt < n && v[pos22-pt] == v[pos22+pt]){
            freq2[v[pos22-pt]]=1;
            pt++;
        }
        for(int i = 0; i < (n/2) +1 ;i++){
            if(freq1[i] == 0){
                mx = max(i, mx);
                break;
            }
        }
        for(int i = 0; i < (n/2) +1 ;i++){

            if(freq2[i] == 0){
                mx = max(i, mx);
                break;
            }
        }


        cout << mx << '\n';
    }
    return 0;
}
