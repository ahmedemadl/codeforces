#include <bits/stdc++.h>
using namespace std;
#define ll long long

int main(){
    cin.tie(0)->sync_with_stdio(0);
    int t; cin >> t;
    while(t--){
        int n , k;cin >> n >> k;
        vector<int> a(n), b(n);
        for(int i = 0 ;i < n;i++){
            int num;cin >> num;
            a[i] = num % k;
            a[i] = min(k - a[i],a[i]);
        }
        for(int i = 0 ;i < n;i++){
            int num;cin >> num;
            b[i] = num % k;
            b[i] = min( k-b[i], b[i]);
        }
        sort(a.begin() , a.end());
        sort(b.begin() , b.end());
        if(a == b)cout << "YES\n";
        else cout << "NO\n";
    }
    return 0;
}
