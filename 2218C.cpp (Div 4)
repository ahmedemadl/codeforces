#include <bits/stdc++.h>
using namespace std;
#define ll long long

int main(){
    cin.tie(0)->sync_with_stdio(0);
    int t; cin >> t;
    while(t--){
        int n;cin >> n;
        int j=0;
        for(int i = 1; i <= n ; i++, j++){
            cout << i << " " << i + n +j  << " "<< i + n +1+j << " ";
        }
        cout << '\n';
    }
    return 0;
}
