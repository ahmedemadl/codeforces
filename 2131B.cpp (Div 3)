#include <bits/stdc++.h>
using namespace std;
#define ll long long

int main(){
    cin.tie(0)->sync_with_stdio(0);
    int t; cin >> t;
    while(t--){
        int n;cin >> n;
        if(n == 2){
            cout << -1 << " " << 2 << '\n';
            continue;
        }
        for(int i = 1; i <= n; i++){
            if(i&1){
                cout << -1 << " ";
            }else{
                if(i == n) cout<< 2 << '\n';
                else cout << 3 << " ";
            }
        }
        cout << '\n';
    }
    return 0;
}
