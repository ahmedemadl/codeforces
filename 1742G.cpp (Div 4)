#include <bits/stdc++.h>
using namespace std;
#define ll long long

int main(){
    cin.tie(0)->sync_with_stdio(0);
    int t; cin >> t;
    while(t--){
        int n;cin >> n;
        vector<int> v(n);
        int OR = 0;
        for(int i = 0 ; i < n;i++){
            cin >> v[i];
            OR|= v[i];
        }
        sort(v.rbegin(), v.rend());
        int cur = v[0];
        cout << v[0] << " ";
        v.erase(v.begin(), v.begin()+1);
        while(cur != OR){
            int mx=cur;
            int pos=0;
            for(int i = 0 ; i < v.size();i++){
                if((cur | v[i]) > mx){
                    pos = i;
                    mx = (cur | v[i]);
                }
            }
            cout << v[pos] << " ";
            cur|= v[pos];
            v.erase(v.begin()+pos, v.begin()+pos+1);
        }
        for(int x : v)cout << x << " ";
        cout << '\n';

    }
    return 0;
}
