#include <bits/stdc++.h>
using namespace std;
#define ll long long

int main(){
    cin.tie(0)->sync_with_stdio(0);
    int t; cin >> t;
    while(t--){
        int n;cin >> n;
        vector<int> a(n),b(n);
        for(auto &i : a) cin >> i;
        for(auto &i : b) cin >> i;
        ll count = 0;
        for(int i = 0 ;i < n; i++){
            if(a[i] > b[i]){
                count += (a[i] - b[i]);
            }
        }
        cout << count + 1 << '\n';
    }
    return 0;
}
