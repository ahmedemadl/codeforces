    int t; cin >> t;
    while(t--){
        int n;cin >> n;
        int freq[31] ={0};
        int ans = 0;
        vector<int> v(n);

        for(int i = 0 ;i < n;i++){
            cin >> v[i];
        }
        for(int i = 0 ;i <n; i++){
            int mx = 0;

            for(int j = 0; j < n; j++){
                mx = max(mx,v[i]^v[j]);
            }
            ans = max(mx, ans);
        }

        cout << ans << '\n';
    }
