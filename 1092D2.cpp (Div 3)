#include <bits/stdc++.h>
using namespace std;
#define ll long long

int main(){
    cin.tie(0)->sync_with_stdio(0);
    int n;cin >> n;
    stack<int>v;
    int maxi = 0;
    for(int i = 0; i < n;i++){
        int num;cin >> num;
        if(!v.empty() && (v.top() == num)){
            maxi = max(maxi, num);
        }else{
            v.push(num);
        }
    }
    if(v.size() == 0 || (v.size() == 1 && maxi <= v.top())) cout << "YES";
    else cout << "NO";
    return 0;
}
