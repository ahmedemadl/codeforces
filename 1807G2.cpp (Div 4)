#include <bits/stdc++.h>
using namespace std;
#define ll long long

int main(){
    cin.tie(0)->sync_with_stdio(0);
    int t; cin >> t;
    while(t--){
        int n;cin >> n;
        vector<ll> v(n);
        for(ll &i : v) cin >> i;
        sort(v.begin(), v.end());
        if(v[0]  != 1){
            cout << "NO\n";
            continue;
        }
        ll sum = 1; 
        bool valid=1;
        
        for(int i = 1 ;i < n;i++){
            
            if(sum < v[i]){
                valid = 0;
                break;
            }
            sum += v[i];
        }
        cout <<(valid ? "YES" : "NO") << '\n';
    }
    return 0;
}
