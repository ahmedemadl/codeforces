#include <bits/stdc++.h>
using namespace std;
#define ll long long

int main(){
    cin.tie(0)->sync_with_stdio(0);
    int n , k;cin >> n >> k;
    vector<int> odd, even;
    for(int i =1 ;i <= n; i++){
        if(i&1) odd.push_back(i);
        else even.push_back(i);
    }
    bool flag=1;
    int pt1=0, pt2=0;
    vector<int> ans(n);
    int j =0;
    int cur =1;
    for(int i = 0;i < k;i++){
        for(int j = 0 ; j < (n/k) +1; j++){
            if(i + (j*k) < n){
                ans[i + (j*k)] = cur;
                cur ++;
            }
        }
    }
    for(int i : ans) cout << i << " ";
    return 0;
}
