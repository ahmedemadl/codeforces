#include <bits/stdc++.h>
using namespace std;
#define ll long long

int main(){
    cin.tie(0)->sync_with_stdio(0);
    int t; cin >> t;
    while(t--){
        int n;cin >> n;
        vector<ll> v(n),op(n);
        for(ll &i : v)cin >> i;
        string s;cin >> s;
        ll ans=0;
        for(int l = 0, r=n-1 ; l < r;l++, r--){
            if(l >= r)break;
            if(s[l] == 'L' && s[r] == 'R'){
                op[l]=1;
                if(r+1 < n)
                    op[r+1]=-1;
            }
            else if(s[l] == 'L'){
                while (l < r){
                    r--;
                    if(s[r] == 'R'){
                        op[l]=1;
                        if(r+1 < n)
                            op[r+1]=-1;
                        break;
                    }
                }

            }else if(s[r] == 'R'){
                while (l < r){
                    l++;
                    if(s[l] == 'L'){
                        op[l]=1;
                        if(r+1 < n)
                            op[r+1]=-1;
                        break;
                    }
                }
            }
        }
        int d=0;
        for(int i = 0 ;i < n;i++){
            d+= op[i];

            ans += d*v[i];
        }
        cout << ans << '\n';
    }
    return 0;
}
