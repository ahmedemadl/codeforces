#include <bits/stdc++.h>
using namespace std;
#define ll long long

int main(){
    cin.tie(0)->sync_with_stdio(0);
    int t; cin >> t;
    while(t--){
        int n, k;cin >> n >> k;
        string s;cin >> s;
        bool valid =1;
        for(int i = 0 ; i + k < n;i++){
            if(s[i] == '1'){
                s[i] = '0';
                if(i + k  >= n){
                    valid =0;
                    break;
                }else{
                    if (s[i+k] == '1')s[i+k] = '0';
                    else s[i+k] = '1';
                }
             }
        }
        for(auto c : s){
            if(c == '1'){
                valid = 0;
                break;
            }
        }
        cout << (valid == 1 ? "YES\n" : "NO\n");
    }
    return 0;
}
